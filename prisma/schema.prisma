generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  phone          String?
  smsApiKey      String?
  smsSender      String?
  welcomeMessage String?
  plan           Plan        @default(TRIAL)
  planExpiresAt  DateTime?
  createdAt      DateTime    @default(now())
  customers      Customer[]
  campaigns      Campaign[]
  smsLogs        SmsLog[]
  adminUsers     AdminUser[]
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String
  passwordHash String
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now())

  @@unique([username, tenantId])
}

model Customer {
  id         String   @id @default(cuid())
  phone      String
  points     Int      @default(0)
  tier       Tier     @default(BRONZE)
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  visits     Visit[]
  createdAt  DateTime @default(now())

  @@unique([phone, tenantId])
}

model Visit {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  tenantId   String
  createdAt  DateTime @default(now())
}

model Campaign {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  title       String
  message     String
  targetTier  Tier?
  scheduledAt DateTime?
  sentAt      DateTime?
  status      CampaignStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
}

model SmsLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  phone     String
  message   String
  status    String
  createdAt DateTime @default(now())
}

enum Plan {
  TRIAL
  MONTHLY
  YEARLY
  LIFETIME
}

enum Tier {
  BRONZE
  SILVER
  GOLD
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}
